<?xml version="1.0" encoding="utf-8"?>
<!--
   Auto-backup and device-transfer rules. The iOS app is .none for cloudKitDatabase
   (pure local + Firebase). Mirror that here — local SQLite/DataStore is not
   eligible for cloud backup, so users can't accidentally restore stale data
   onto a new device that they've also been syncing to Firestore from.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
